generator client {
  provider        = "prisma-client-js"
  output          = "../src/prisma"
  previewFeatures = ["partialIndexes"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model categories {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name              String              @unique @db.VarChar(100)
  icon_url          String?
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?           @db.Timestamptz(6)
  created_by        String?             @db.Uuid
  updated_by        String?             @db.Uuid
  shifts            shifts[]
  skills            skills[]
  worker_categories worker_categories[]
}

model cities {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String            @unique @db.VarChar(100)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?         @db.Timestamptz(6)
  created_by      String?           @db.Uuid
  updated_by      String?           @db.Uuid
  worker_profiles worker_profiles[]
  zones           zones[]
}

model devices {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @db.Uuid
  device_token String?
  platform     String?   @db.VarChar(10)
  device_model String?   @db.VarChar(100)
  app_version  String?   @db.VarChar(20)
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at   DateTime? @db.Timestamptz(6)
  created_by   String?   @db.Uuid
  updated_by   String?   @db.Uuid
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_devices_user_id")
}

model otp_requests {
  id         String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone      String           @db.VarChar(15)
  otp_code   String           @db.VarChar(64)
  purpose    otp_purpose_enum @default(login)
  is_used    Boolean          @default(false)
  expires_at DateTime         @db.Timestamptz(6)
  created_at DateTime         @default(now()) @db.Timestamptz(6)
  updated_at DateTime         @default(now()) @db.Timestamptz(6)
  deleted_at DateTime?        @db.Timestamptz(6)
  created_by String?          @db.Uuid
  updated_by String?          @db.Uuid

  @@index([expires_at], map: "idx_otp_expires_at")
  @@index([phone, purpose], map: "idx_otp_phone_purpose")
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  session_id String    @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique
  is_revoked Boolean   @default(false)
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  sessions   sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_refresh_tokens_user_id")
}

model sessions {
  id             String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String              @db.Uuid
  access_token   String              @unique
  status         session_status_enum @default(active)
  expires_at     DateTime            @db.Timestamptz(6)
  ip_address     String?             @db.Inet
  user_agent     String?
  created_at     DateTime            @default(now()) @db.Timestamptz(6)
  updated_at     DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at     DateTime?           @db.Timestamptz(6)
  created_by     String?             @db.Uuid
  updated_by     String?             @db.Uuid
  refresh_tokens refresh_tokens[]
  users          users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_sessions_user_id")
}

model skills {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String          @unique @db.VarChar(100)
  category_id   String?         @db.Uuid
  is_active     Boolean         @default(true)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at    DateTime        @default(now()) @db.Timestamptz(6)
  deleted_at    DateTime?       @db.Timestamptz(6)
  created_by    String?         @db.Uuid
  updated_by    String?         @db.Uuid
  categories    categories?     @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker_skills worker_skills[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model users {
  id                                                  String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone                                               String             @unique @db.VarChar(15)
  email                                               String?            @unique @db.VarChar(255)
  full_name                                           String?            @db.VarChar(100)
  profile_picture                                     String?
  roles                                               String[]           @default([])
  is_active                                           Boolean            @default(true)
  is_phone_verified                                   Boolean            @default(false)
  created_at                                          DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                                          DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at                                          DateTime?          @db.Timestamptz(6)
  created_by                                          String?            @db.Uuid
  updated_by                                          String?            @db.Uuid
  business_profiles                                   business_profiles?
  chat_messages                                       chat_messages[]
  devices                                             devices[]
  disputes_disputes_against_userTousers               disputes[]         @relation("disputes_against_userTousers")
  disputes_disputes_raised_byTousers                  disputes[]         @relation("disputes_raised_byTousers")
  disputes_disputes_resolved_byTousers                disputes[]         @relation("disputes_resolved_byTousers")
  notifications                                       notifications[]
  payout_requests_payout_requests_processed_byTousers payout_requests[]  @relation("payout_requests_processed_byTousers")
  payout_requests_payout_requests_user_idTousers      payout_requests[]  @relation("payout_requests_user_idTousers")
  ratings_ratings_rated_user_idTousers                ratings[]          @relation("ratings_rated_user_idTousers")
  ratings_ratings_rater_user_idTousers                ratings[]          @relation("ratings_rater_user_idTousers")
  refresh_tokens                                      refresh_tokens[]
  reports_reports_reported_idTousers                  reports[]          @relation("reports_reported_idTousers")
  reports_reports_reporter_idTousers                  reports[]          @relation("reports_reporter_idTousers")
  reports_reports_resolved_byTousers                  reports[]          @relation("reports_resolved_byTousers")
  sessions                                            sessions[]
  user_sanctions_user_sanctions_issued_byTousers      user_sanctions[]   @relation("user_sanctions_issued_byTousers")
  user_sanctions_user_sanctions_user_idTousers        user_sanctions[]   @relation("user_sanctions_user_idTousers")
  wallets                                             wallets?
  worker_profiles                                     worker_profiles?

  @@index([deleted_at], map: "idx_users_deleted_at", where: raw("(deleted_at IS NULL)"))
  @@index([phone], map: "idx_users_phone")
  @@index([roles], map: "idx_users_roles", type: Gin)
}

model zones {
  id                     String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  city_id                String                    @db.Uuid
  name                   String                    @db.VarChar(100)
  coordinates            Unsupported("geography")?
  boundary               Unsupported("geography")?
  is_active              Boolean                   @default(true)
  created_at             DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                  @default(now()) @db.Timestamptz(6)
  deleted_at             DateTime?                 @db.Timestamptz(6)
  created_by             String?                   @db.Uuid
  updated_by             String?                   @db.Uuid
  business_branches      business_branches[]
  business_profiles      business_profiles[]
  shifts                 shifts[]
  worker_preferred_zones worker_preferred_zones[]
  cities                 cities                    @relation(fields: [city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([city_id, name])
  @@index([boundary], map: "idx_zones_boundary", type: Gist)
  @@index([coordinates], map: "idx_zones_coordinates", type: Gist)
}

model applications {
  id                 String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shift_id           String                  @db.Uuid
  worker_profile_id  String                  @db.Uuid
  status             application_status_enum @default(pending)
  applied_at         DateTime                @default(now()) @db.Timestamptz(6)
  note               String?
  created_at         DateTime                @default(now()) @db.Timestamptz(6)
  updated_at         DateTime                @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?               @db.Timestamptz(6)
  created_by         String?                 @db.Uuid
  updated_by         String?                 @db.Uuid
  shifts             shifts                  @relation(fields: [shift_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker_profiles    worker_profiles         @relation(fields: [worker_profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker_assignments worker_assignments[]

  @@unique([shift_id, worker_profile_id])
  @@index([shift_id], map: "idx_applications_shift")
  @@index([status], map: "idx_applications_status")
  @@index([worker_profile_id], map: "idx_applications_worker")
}

model business_branches {
  id                  String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_profile_id String                    @db.Uuid
  branch_name         String                    @db.VarChar(200)
  address             String?
  landmark            String?
  coordinates         Unsupported("geography")?
  zone_id             String?                   @db.Uuid
  is_active           Boolean                   @default(true)
  created_at          DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime                  @default(now()) @db.Timestamptz(6)
  deleted_at          DateTime?                 @db.Timestamptz(6)
  created_by          String?                   @db.Uuid
  updated_by          String?                   @db.Uuid
  business_profiles   business_profiles         @relation(fields: [business_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zones               zones?                    @relation(fields: [zone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shifts              shifts[]
}

model business_favorite_workers {
  business_profile_id String            @db.Uuid
  worker_profile_id   String            @db.Uuid
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  business_profiles   business_profiles @relation(fields: [business_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker_profiles     worker_profiles   @relation(fields: [worker_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([business_profile_id, worker_profile_id])
}

model business_profiles {
  id                        String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                   String                      @unique @db.Uuid
  business_name             String                      @db.VarChar(200)
  business_type             String?                     @db.VarChar(100)
  logo_url                  String?
  manager_name              String?                     @db.VarChar(100)
  manager_phone             String?                     @db.VarChar(15)
  address                   String?
  landmark                  String?
  coordinates               Unsupported("geography")?
  zone_id                   String?                     @db.Uuid
  trade_license_url         String?
  business_doc_url          String?
  verification_status       verification_status_enum    @default(unverified)
  verification_note         String?
  meal_included             Boolean                     @default(false)
  transport_support         Boolean                     @default(false)
  female_friendly           Boolean                     @default(false)
  uniform_required          Boolean                     @default(false)
  reliability_score         Decimal?                    @default(0) @db.Decimal(4, 2)
  cancellation_rate         Decimal?                    @default(0) @db.Decimal(5, 2)
  payment_reliability       Decimal?                    @default(0) @db.Decimal(5, 2)
  dispute_count             Int                         @default(0)
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                    @default(now()) @db.Timestamptz(6)
  deleted_at                DateTime?                   @db.Timestamptz(6)
  created_by                String?                     @db.Uuid
  updated_by                String?                     @db.Uuid
  business_branches         business_branches[]
  business_favorite_workers business_favorite_workers[]
  users                     users                       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zones                     zones?                      @relation(fields: [zone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  chat_conversations        chat_conversations[]
  shifts                    shifts[]

  @@index([coordinates], map: "idx_business_coordinates", type: Gist)
  @@index([user_id], map: "idx_business_profiles_user_id")
  @@index([zone_id], map: "idx_business_profiles_zone")
}

model disputes {
  id                                 String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  report_id                          String?            @db.Uuid
  shift_id                           String?            @db.Uuid
  raised_by                          String             @db.Uuid
  against_user                       String             @db.Uuid
  description                        String?
  status                             report_status_enum @default(open)
  resolved_by                        String?            @db.Uuid
  resolution_note                    String?
  created_at                         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at                         DateTime?          @db.Timestamptz(6)
  created_by                         String?            @db.Uuid
  updated_by                         String?            @db.Uuid
  users_disputes_against_userTousers users              @relation("disputes_against_userTousers", fields: [against_user], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_disputes_raised_byTousers    users              @relation("disputes_raised_byTousers", fields: [raised_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reports                            reports?           @relation(fields: [report_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_disputes_resolved_byTousers  users?             @relation("disputes_resolved_byTousers", fields: [resolved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shifts                             shifts?            @relation(fields: [shift_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model notifications {
  id             String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String                     @db.Uuid
  type           notification_type_enum
  priority       notification_priority_enum @default(normal)
  title          String                     @db.VarChar(200)
  body           String
  data           Json?
  is_read        Boolean                    @default(false)
  read_at        DateTime?                  @db.Timestamptz(6)
  delivered_at   DateTime?                  @db.Timestamptz(6)
  failed_at      DateTime?                  @db.Timestamptz(6)
  failure_reason String?
  created_at     DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime                   @default(now()) @db.Timestamptz(6)
  deleted_at     DateTime?                  @db.Timestamptz(6)
  created_by     String?                    @db.Uuid
  updated_by     String?                    @db.Uuid
  users          users                      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_notifications_created_at")
  @@index([user_id, is_read], map: "idx_notifications_unread", where: raw("(is_read = false)"))
  @@index([user_id], map: "idx_notifications_user")
}

model payout_requests {
  id                                        String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  wallet_id                                 String              @db.Uuid
  user_id                                   String              @db.Uuid
  amount                                    Decimal             @db.Decimal(10, 2)
  method                                    payment_method_enum
  account_number                            String              @db.VarChar(20)
  account_name                              String?             @db.VarChar(100)
  status                                    payment_status_enum @default(pending)
  processed_by                              String?             @db.Uuid
  processed_at                              DateTime?           @db.Timestamptz(6)
  failure_reason                            String?
  created_at                                DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                                DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at                                DateTime?           @db.Timestamptz(6)
  created_by                                String?             @db.Uuid
  updated_by                                String?             @db.Uuid
  users_payout_requests_processed_byTousers users?              @relation("payout_requests_processed_byTousers", fields: [processed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_payout_requests_user_idTousers      users               @relation("payout_requests_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wallets                                   wallets             @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_payout_requests_status")
  @@index([user_id], map: "idx_payout_requests_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ratings {
  id                                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shift_id                           String              @db.Uuid
  assignment_id                      String?             @db.Uuid
  rater_user_id                      String              @db.Uuid
  rated_user_id                      String              @db.Uuid
  overall_score                      Int                 @db.SmallInt
  punctuality_score                  Int?                @db.SmallInt
  behavior_score                     Int?                @db.SmallInt
  skill_score                        Int?                @db.SmallInt
  review                             String?
  is_anonymous                       Boolean             @default(false)
  created_at                         DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at                         DateTime?           @db.Timestamptz(6)
  created_by                         String?             @db.Uuid
  updated_by                         String?             @db.Uuid
  worker_assignments                 worker_assignments? @relation(fields: [assignment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_ratings_rated_user_idTousers users               @relation("ratings_rated_user_idTousers", fields: [rated_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_ratings_rater_user_idTousers users               @relation("ratings_rater_user_idTousers", fields: [rater_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shifts                             shifts              @relation(fields: [shift_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([shift_id, rater_user_id, rated_user_id])
  @@index([rated_user_id], map: "idx_ratings_rated_user")
  @@index([shift_id], map: "idx_ratings_shift")
}

model reports {
  id                               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shift_id                         String?            @db.Uuid
  reporter_id                      String             @db.Uuid
  reported_id                      String             @db.Uuid
  report_type                      report_type_enum
  description                      String?
  evidence_urls                    String[]
  status                           report_status_enum @default(open)
  resolved_by                      String?            @db.Uuid
  resolved_note                    String?
  created_at                       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at                       DateTime?          @db.Timestamptz(6)
  created_by                       String?            @db.Uuid
  updated_by                       String?            @db.Uuid
  disputes                         disputes[]
  users_reports_reported_idTousers users              @relation("reports_reported_idTousers", fields: [reported_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_reports_reporter_idTousers users              @relation("reports_reporter_idTousers", fields: [reporter_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_reports_resolved_byTousers users?             @relation("reports_resolved_byTousers", fields: [resolved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shifts                           shifts?            @relation(fields: [shift_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([reported_id], map: "idx_reports_reported")
  @@index([reporter_id], map: "idx_reports_reporter")
  @@index([status], map: "idx_reports_status")
}

model shifts {
  id                  String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_profile_id String                    @db.Uuid
  branch_id           String?                   @db.Uuid
  title               String                    @db.VarChar(200)
  description         String?
  category_id         String                    @db.Uuid
  role_type           String?                   @db.VarChar(100)
  shift_type          shift_type_enum           @default(scheduled)
  shift_date          DateTime                  @db.Date
  start_time          DateTime                  @db.Time(6)
  end_time            DateTime                  @db.Time(6)
  pay_amount          Decimal                   @db.Decimal(10, 2)
  currency            String                    @default("BDT") @db.VarChar(3)
  workers_needed      Int                       @default(1) @db.SmallInt
  gender_preference   gender_enum?
  meal_included       Boolean                   @default(false)
  transport_support   Boolean                   @default(false)
  address             String?
  landmark            String?
  coordinates         Unsupported("geography")?
  zone_id             String?                   @db.Uuid
  status              shift_status_enum         @default(draft)
  cancellation_reason String?
  created_at          DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime                  @default(now()) @db.Timestamptz(6)
  deleted_at          DateTime?                 @db.Timestamptz(6)
  created_by          String?                   @db.Uuid
  updated_by          String?                   @db.Uuid
  checkin_qr_token    String                    @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  applications        applications[]
  chat_conversations  chat_conversations[]
  disputes            disputes[]
  ratings             ratings[]
  reports             reports[]
  business_branches   business_branches?        @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  business_profiles   business_profiles         @relation(fields: [business_profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categories          categories                @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  zones               zones?                    @relation(fields: [zone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions        transactions[]
  worker_assignments  worker_assignments[]

  @@index([business_profile_id], map: "idx_shifts_business")
  @@index([category_id], map: "idx_shifts_category")
  @@index([coordinates], map: "idx_shifts_coordinates", type: Gist)
  @@index([shift_date], map: "idx_shifts_date")
  @@index([deleted_at], map: "idx_shifts_deleted_at", where: raw("(deleted_at IS NULL)"))
  @@index([status], map: "idx_shifts_status")
  @@index([status, shift_date], map: "idx_shifts_status_date")
  @@index([zone_id], map: "idx_shifts_zone")
}

model transactions {
  id                 String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  wallet_id          String                @db.Uuid
  shift_id           String?               @db.Uuid
  assignment_id      String?               @db.Uuid
  type               transaction_type_enum
  amount             Decimal               @db.Decimal(10, 2)
  balance_after      Decimal               @db.Decimal(12, 2)
  description        String?
  reference_id       String?               @db.VarChar(100)
  created_at         DateTime              @default(now()) @db.Timestamptz(6)
  updated_at         DateTime              @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?             @db.Timestamptz(6)
  created_by         String?               @db.Uuid
  updated_by         String?               @db.Uuid
  worker_assignments worker_assignments?   @relation(fields: [assignment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shifts             shifts?               @relation(fields: [shift_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wallets            wallets               @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_transactions_created_at")
  @@index([shift_id], map: "idx_transactions_shift")
  @@index([wallet_id], map: "idx_transactions_wallet")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_sanctions {
  id                                    String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                               String                 @db.Uuid
  sanction_type                         String                 @db.VarChar(20)
  reason                                String
  severity                              incident_severity_enum @default(low)
  issued_by                             String                 @db.Uuid
  expires_at                            DateTime?              @db.Timestamptz(6)
  is_active                             Boolean                @default(true)
  created_at                            DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at                            DateTime?              @db.Timestamptz(6)
  created_by                            String?                @db.Uuid
  updated_by                            String?                @db.Uuid
  users_user_sanctions_issued_byTousers users                  @relation("user_sanctions_issued_byTousers", fields: [issued_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_user_sanctions_user_idTousers   users                  @relation("user_sanctions_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_sanctions_user")
}

model wallets {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String            @unique @db.Uuid
  balance         Decimal           @default(0.00) @db.Decimal(12, 2)
  total_earned    Decimal           @default(0.00) @db.Decimal(12, 2)
  total_withdrawn Decimal           @default(0.00) @db.Decimal(12, 2)
  currency        String            @default("BDT") @db.VarChar(3)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?         @db.Timestamptz(6)
  created_by      String?           @db.Uuid
  updated_by      String?           @db.Uuid
  payout_requests payout_requests[]
  transactions    transactions[]
  users           users             @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model worker_assignments {
  id                String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shift_id          String               @db.Uuid
  application_id    String               @db.Uuid
  worker_profile_id String               @db.Uuid
  checkin_method    checkin_method_enum?
  checked_in_at     DateTime?            @db.Timestamptz(6)
  checked_out_at    DateTime?            @db.Timestamptz(6)
  payment_status    payment_status_enum  @default(pending)
  created_at        DateTime             @default(now()) @db.Timestamptz(6)
  updated_at        DateTime             @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?            @db.Timestamptz(6)
  created_by        String?              @db.Uuid
  updated_by        String?              @db.Uuid
  ratings           ratings[]
  transactions      transactions[]
  applications      applications         @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shifts            shifts               @relation(fields: [shift_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker_profiles   worker_profiles      @relation(fields: [worker_profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([shift_id, worker_profile_id])
  @@index([shift_id], map: "idx_assignments_shift")
  @@index([worker_profile_id], map: "idx_assignments_worker")
}

model worker_categories {
  worker_profile_id String          @db.Uuid
  category_id       String          @db.Uuid
  categories        categories      @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker_profiles   worker_profiles @relation(fields: [worker_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([worker_profile_id, category_id])
}

model worker_preferred_zones {
  worker_profile_id String          @db.Uuid
  zone_id           String          @db.Uuid
  worker_profiles   worker_profiles @relation(fields: [worker_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zones             zones           @relation(fields: [zone_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([worker_profile_id, zone_id])
}

model worker_profiles {
  id                        String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                   String                      @unique @db.Uuid
  gender                    gender_enum?
  date_of_birth             DateTime?                   @db.Date
  city_id                   String?                     @db.Uuid
  travel_radius_km          Int?                        @default(10) @db.SmallInt
  availability_days         String[]
  availability_slots        String[]
  nid_front_url             String?
  nid_back_url              String?
  selfie_url                String?
  student_id_url            String?
  verification_status       verification_status_enum    @default(unverified)
  verification_note         String?
  reliability_score         Decimal?                    @default(0) @db.Decimal(4, 2)
  attendance_rate           Decimal?                    @default(0) @db.Decimal(5, 2)
  completion_rate           Decimal?                    @default(0) @db.Decimal(5, 2)
  response_rate             Decimal?                    @default(0) @db.Decimal(5, 2)
  no_show_count             Int                         @default(0)
  completed_shift_count     Int                         @default(0)
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                    @default(now()) @db.Timestamptz(6)
  deleted_at                DateTime?                   @db.Timestamptz(6)
  created_by                String?                     @db.Uuid
  updated_by                String?                     @db.Uuid
  full_name                 String?                     @db.VarChar(100)
  profile_picture           String?
  applications              applications[]
  business_favorite_workers business_favorite_workers[]
  chat_conversations        chat_conversations[]
  worker_assignments        worker_assignments[]
  worker_categories         worker_categories[]
  worker_preferred_zones    worker_preferred_zones[]
  cities                    cities?                     @relation(fields: [city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                     users                       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker_skills             worker_skills[]

  @@index([city_id], map: "idx_worker_profiles_city_id")
  @@index([user_id], map: "idx_worker_profiles_user_id")
  @@index([verification_status], map: "idx_worker_profiles_verification")
}

model worker_skills {
  worker_profile_id String          @db.Uuid
  skill_id          String          @db.Uuid
  skills            skills          @relation(fields: [skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker_profiles   worker_profiles @relation(fields: [worker_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([worker_profile_id, skill_id])
}

model chat_conversations {
  id                  String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shift_id            String            @db.Uuid
  worker_profile_id   String            @db.Uuid
  business_profile_id String            @db.Uuid
  last_message_at     DateTime?         @db.Timestamptz(6)
  last_message_text   String?
  last_sender_role    String?           @db.VarChar(10)
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)
  deleted_at          DateTime?         @db.Timestamptz(6)
  created_by          String?           @db.Uuid
  updated_by          String?           @db.Uuid
  business_profiles   business_profiles @relation(fields: [business_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  shifts              shifts            @relation(fields: [shift_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker_profiles     worker_profiles   @relation(fields: [worker_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chat_messages       chat_messages[]

  @@unique([shift_id, worker_profile_id])
  @@index([business_profile_id], map: "idx_chat_conversations_business")
  @@index([last_message_at(sort: Desc)], map: "idx_chat_conversations_last_msg")
  @@index([shift_id], map: "idx_chat_conversations_shift")
  @@index([worker_profile_id], map: "idx_chat_conversations_worker")
}

model chat_messages {
  id                 String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  conversation_id    String             @db.Uuid
  sender_user_id     String             @db.Uuid
  sender_role        String             @db.VarChar(10)
  body               String
  read_at            DateTime?          @db.Timestamptz(6)
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?          @db.Timestamptz(6)
  chat_conversations chat_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users              @relation(fields: [sender_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversation_id, created_at(sort: Desc)], map: "idx_chat_messages_conversation")
  @@index([conversation_id, sender_role, read_at], map: "idx_chat_messages_unread")
}

