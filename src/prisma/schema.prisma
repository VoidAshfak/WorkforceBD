generator client {
  provider   = "prisma-client-js"
  output     = "../src/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model categories {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String    @unique @db.VarChar(100)
  icon_url   String?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  skills     skills[]
}

model cities {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String    @unique @db.VarChar(100)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  zones      zones[]
}

model devices {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @db.Uuid
  device_token String?
  platform     String?   @db.VarChar(10)
  device_model String?   @db.VarChar(100)
  app_version  String?   @db.VarChar(20)
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at   DateTime? @db.Timestamptz(6)
  created_by   String?   @db.Uuid
  updated_by   String?   @db.Uuid
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model otp_requests {
  id         String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone      String           @db.VarChar(15)
  otp_code   String           @db.VarChar(6)
  purpose    otp_purpose_enum @default(login)
  is_used    Boolean          @default(false)
  expires_at DateTime         @db.Timestamptz(6)
  created_at DateTime         @default(now()) @db.Timestamptz(6)
  updated_at DateTime         @default(now()) @db.Timestamptz(6)
  deleted_at DateTime?        @db.Timestamptz(6)
  created_by String?          @db.Uuid
  updated_by String?          @db.Uuid
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  session_id String    @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique
  is_revoked Boolean   @default(false)
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  sessions   sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model sessions {
  id             String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String              @db.Uuid
  access_token   String              @unique
  status         session_status_enum @default(active)
  expires_at     DateTime            @db.Timestamptz(6)
  ip_address     String?             @db.Inet
  user_agent     String?
  created_at     DateTime            @default(now()) @db.Timestamptz(6)
  updated_at     DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at     DateTime?           @db.Timestamptz(6)
  created_by     String?             @db.Uuid
  updated_by     String?             @db.Uuid
  refresh_tokens refresh_tokens[]
  users          users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model skills {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String      @unique @db.VarChar(100)
  category_id String?     @db.Uuid
  is_active   Boolean     @default(true)
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  updated_at  DateTime    @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime?   @db.Timestamptz(6)
  created_by  String?     @db.Uuid
  updated_by  String?     @db.Uuid
  categories  categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model users {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone             String           @unique @db.VarChar(15)
  email             String?          @unique @db.VarChar(255)
  full_name         String?          @db.VarChar(100)
  profile_picture   String?
  roles             String[]         @default([])
  is_active         Boolean          @default(true)
  is_phone_verified Boolean          @default(false)
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime         @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?        @db.Timestamptz(6)
  created_by        String?          @db.Uuid
  updated_by        String?          @db.Uuid
  devices           devices[]
  refresh_tokens    refresh_tokens[]
  sessions          sessions[]
}

model zones {
  id          String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  city_id     String                    @db.Uuid
  name        String                    @db.VarChar(100)
  coordinates Unsupported("geography")?
  boundary    Unsupported("geography")?
  is_active   Boolean                   @default(true)
  created_at  DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime                  @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime?                 @db.Timestamptz(6)
  created_by  String?                   @db.Uuid
  updated_by  String?                   @db.Uuid
  cities      cities                    @relation(fields: [city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([city_id, name])
}

enum application_status_enum {
  pending
  shortlisted
  accepted
  rejected
  withdrawn
  no_show
}

enum checkin_method_enum {
  manual
  gps
  qr
  pin
}

enum gender_enum {
  male
  female
  other
  prefer_not_to_say
}

enum incident_severity_enum {
  low
  medium
  high
  critical
}

enum notification_priority_enum {
  low
  normal
  high
  urgent
}

enum notification_type_enum {
  push
  sms
  in_app
}

enum otp_purpose_enum {
  login
  register
  reset
  verify_phone
}

enum payment_method_enum {
  bkash
  nagad
  bank_transfer
  cash
}

enum payment_status_enum {
  pending
  approved
  sent
  received
  failed
}

enum report_status_enum {
  open
  under_review
  resolved
  dismissed
}

enum report_type_enum {
  unsafe_environment
  abuse
  harassment
  unpaid_work
  no_show
  misconduct
  bad_behavior
  other
}

enum session_status_enum {
  active
  expired
  revoked
}

enum shift_status_enum {
  draft
  published
  applications_open
  worker_selected
  worker_confirmed
  worker_arriving
  checked_in
  active
  completed
  payment_pending
  paid
  closed
  cancelled
}

enum shift_type_enum {
  instant
  scheduled
  prebooked
}

enum transaction_type_enum {
  credit
  debit
}

enum verification_status_enum {
  unverified
  pending
  verified
  rejected
}
